@startuml
left to right direction
skinparam PackageStyle rectangle
skinparam DefaultFontName Arial

actor "Cliente" as cliente
actor "Repartidor" as repartidor
actor "Administrador" as administrador

rectangle "Sistema FastDelivery Perú" {
  (Realizar Pago Online) as u1
  (Registrarse) as u2
  (Realizar Pedido) as u3
  (Consultar Estado de Delivery) as u4
  
  (Recibir Pedido) as u5
  (Actualizar Estado de Entrega) as u6
  
  (Gestionar Inventario) as u7
  (Visualizar Reportes) as u8
  (Gestionar Pedidos) as u9
}

' Relaciones del Cliente
cliente --> u1
cliente --> u2
cliente --> u3
cliente --> u4

' Relaciones del Repartidor
repartidor --> u5
repartidor --> u6

' Relaciones del Administrador
administrador --> u7
administrador --> u8
administrador --> u9

' Dependencias de Casos de Uso
u3 .--> u9 : <<genera>>

@endum
